# Base credentials (shared)
SSH_HOST=your-ssh-host
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=your-password

# PostgreSQL Database Configuration
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=focustodo
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# Frontend API Configuration (leave empty for same-domain backend)
VITE_BACKEND_URL=

# Slack Webhook URL for Task Reminders
VITE_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Realtime via SSE (GET /api/events). Bật 'true' khi deploy long-running
# (server thường) để cập nhật tức thời. Để trống/false trên serverless (Vercel)
# — sẽ dùng poll 25s (serverless không giữ kết nối SSE dài).
VITE_ENABLE_SSE=

# (Tùy chọn) API key tĩnh cũ + admin key để quản lý /api/keys, /api/integrations
# API_KEY=
# ADMIN_KEY=
# APP_ORIGIN=https://your-app.example.com   # cho phép SPA cross-origin nếu cần
