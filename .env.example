# Base credentials (shared) - THAY THE BANG GIA TRI THUC TRUOC KHI DEPLOY
SSH_HOST=your-ssh-host
SSH_PORT=22
SSH_USER=root
SSH_PASSWORD=your-strong-ssh-password

# PostgreSQL Database Configuration
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=focustodo
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# YouTube Subtitle Database Configuration
YOUTUBE_DB_HOST=your-youtube-db-host
YOUTUBE_DB_PORT=5432
YOUTUBE_DB_NAME=youtube_subtitle
YOUTUBE_DB_USER=your-youtube-db-user
YOUTUBE_DB_PASSWORD=your-youtube-db-password


# JWT Secret - BAT BUOC, it nhat 32 bytes entropy ngau nhien
# Tao bang lenh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-32-bytes-hex-string

# Frontend API Configuration (de trong neu backend cung domain)
VITE_BACKEND_URL=

# Capacitor Mobile App - Backend URL cho thiet bi Android/iOS
# Khi test tren thiet bi that hoac emulator, thiet bi khong the truy cap localhost cua may tinh.
# Thay bang dia chi IP LAN cua may tinh chay server (xem bang lenh: ipconfig)
# Vi du: VITE_CAPACITOR_BACKEND_URL=http://192.168.1.100:4000
# Neu da deploy backend len cloud: VITE_CAPACITOR_BACKEND_URL=https://your-api.example.com
VITE_CAPACITOR_BACKEND_URL=http://192.168.1.100:4000


# Slack Webhook URL - dat o BACKEND (khong dung VITE_ de tranh lo ra client)
# URL lay tu: https://api.slack.com/apps -> Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Realtime via SSE (GET /api/events). Bat 'true' khi deploy long-running server.
# De trong/false tren serverless (Vercel) - se dung poll 25s.
VITE_ENABLE_SSE=

# (Tuy chon) API key tinh cu + admin key de quan ly /api/keys, /api/integrations
# API_KEY=
# ADMIN_KEY=
# APP_ORIGIN=https://your-app.example.com  # cho phep SPA cross-origin neu can
